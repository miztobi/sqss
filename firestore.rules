rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザー自身のデータのアクセス許可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // サブコレクションの再帰的マッチ
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // 資格定義データのアクセス許可（誰でも読み取り可、書き込みはログインユーザーに許可）
    match /goals/{goalId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /{document=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
